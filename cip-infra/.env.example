# ============================================================
# CIP Infrastructure — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
REDIS_PASSWORD=cip-redis-pass

# ── Service Ports ─────────────────────────────────────────────
# WebSocket: 3001, Job Worker: 3002, Storage: 3003
# Kafka UI: 8090, Prometheus: 9090, Grafana: 3004

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:29092

# ── WebSocket ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Storage ──────────────────────────────────────────────────
# Options: "local" or "s3"
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/data
SIGNED_URL_EXPIRY=3600
MAX_FILE_SIZE_MB=10

# AWS S3 (only needed if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=cip-resumes

# ── Job Ingestion ─────────────────────────────────────────────
JOB_FETCH_INTERVAL_MINUTES=15

# ATS API Keys (leave blank to disable that source)
GREENHOUSE_API_KEY=
LEVER_API_KEY=
ASHBY_API_KEY=

# ── Logging ───────────────────────────────────────────────────
# Options: error, warn, info, debug
LOG_LEVEL=info

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
